# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env.local and fill in your credentials
# Never commit actual secrets to version control!
# ============================================================

# ============================================================
# BETTER-AUTH Configuration
# ============================================================
# Generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3003

# ============================================================
# Stripe Configuration
# https://dashboard.stripe.com/apikeys
# ============================================================
# Public key (can be exposed in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key (must be server-side only)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret (from Webhooks section)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================
# Supabase Configuration (Optional)
# https://supabase.com/dashboard
# ============================================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================
# Application Configuration
# ============================================================
# Environment stage
NODE_ENV=development

# Application name
NEXT_PUBLIC_APP_NAME=nextjs-expo-monorepo

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3003
