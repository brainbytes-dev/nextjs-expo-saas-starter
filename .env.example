# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env.local and fill in your credentials
# Never commit actual secrets to version control!
# ============================================================

# ============================================================
# BETTER-AUTH Configuration
# ============================================================
# Generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3003

# ============================================================
# Stripe Configuration
# https://dashboard.stripe.com/apikeys
# ============================================================
# Public key (can be exposed in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key (must be server-side only)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret (from Webhooks section)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================
# Supabase Configuration (Optional)
# https://supabase.com/dashboard
# ============================================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================
# RevenueCat Configuration (Mobile In-App Purchases)
# https://www.revenuecat.com/
# ============================================================
# RevenueCat public API key (for mobile app)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_YourPublicKeyHere

# RevenueCat server-side API key (for webhooks)
REVENUECAT_API_KEY=your_api_key_here

# ============================================================
# Resend Configuration (Email Delivery)
# https://resend.com/api-keys
# ============================================================
# Resend API key (server-side only)
RESEND_API_KEY=re_your_api_key_here

# ============================================================
# Sentry Configuration (Error Tracking)
# https://sentry.io/
# ============================================================
# Sentry DSN for web app (can be exposed in browser)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_key@sentry.io/project_id

# Sentry auth token for deployment (server-side only)
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# Sentry DSN for mobile app (can be exposed)
EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_key@sentry.io/mobile_project_id

# ============================================================
# Upstash Redis Configuration (Rate Limiting)
# https://console.upstash.com/
# ============================================================
# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# ============================================================
# PostHog Configuration (Product Analytics)
# https://posthog.com/
# ============================================================
# PostHog API key (can be exposed in browser)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_api_key_here

# PostHog host (optional, defaults to US)
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# PostHog key for mobile app
EXPO_PUBLIC_POSTHOG_KEY=phc_your_mobile_api_key_here

# PostHog host for mobile (optional)
EXPO_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ============================================================
# Application Configuration
# ============================================================
# Environment stage
NODE_ENV=development

# Application name
NEXT_PUBLIC_APP_NAME=nextjs-expo-monorepo

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Mobile App URL (for expo tunnels)
EXPO_PUBLIC_APP_URL=exp://localhost:8081
